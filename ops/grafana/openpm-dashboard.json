{
  "__comment": "OpenPM observability dashboard (section W). Import into Grafana; expects a Prometheus datasource scraping the backend /metrics endpoint.",
  "title": "OpenPM",
  "uid": "openpm-overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate (by route)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP latency p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pipeline step duration p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, step) (rate(pipeline_step_duration_seconds_bucket[5m])))",
          "legendFormat": "{{step}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pipeline errors (by class)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (error_class) (rate(pipeline_errors_total[15m]))",
          "legendFormat": "{{error_class}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Extractions (by model/status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (model, status) (rate(extraction_total[15m]))",
          "legendFormat": "{{model}} {{status}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Chat messages (by model)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (model) (rate(chat_messages_total[15m]))",
          "legendFormat": "{{model}}"
        }
      ]
    }
  ]
}
