# Deployment environment: dev | staging | production
# Controls hardening checks at startup (e.g. refuses default encryption key in non-dev).
ENVIRONMENT=dev

# Database
POSTGRES_PASSWORD=changeme

# Auth
SECRET_KEY=min-32-zeichen-zufaelliger-string-hier-aendern
ACCESS_TOKEN_EXPIRE_DAYS=7
# AES-256 key (32 bytes base64) used to encrypt provider credentials at rest
OPENPM_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# LLM + embedding providers — configured via the /settings UI after first login.
# To bootstrap from env vars on first boot, set the values below and run:
#   docker compose exec backend python -m scripts.seed_providers
# Vars consumed by the seed script (not by the running app):
#   SEED_LLM_API_KEY, SEED_LLM_BASE_URL, SEED_LLM_MODEL
#   SEED_EMBEDDING_API_KEY, SEED_EMBEDDING_BASE_URL, SEED_EMBEDDING_MODEL

# Storage
STORAGE_PATH=/storage
MAX_UPLOAD_BYTES=52428800

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Worker
ARQ_MAX_JOBS=5

# Kreuzberg OCR (optional)
KREUZBERG_FORCE_OCR=false
KREUZBERG_OCR_LANGUAGE=deu+eng
