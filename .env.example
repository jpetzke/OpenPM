# Database
POSTGRES_PASSWORD=changeme

# Auth
SECRET_KEY=min-32-zeichen-zufaelliger-string-hier-aendern
ACCESS_TOKEN_EXPIRE_DAYS=7

# LLM
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-...
LLM_MODEL=anthropic/claude-sonnet-4-20250514
# Optional fallback list for OpenRouter 429s, comma-separated.
# If set, this list is tried in order and LLM_MODEL is ignored.
# LLM_MODELS=anthropic/claude-sonnet-4-20250514,openai/gpt-4.1-mini,google/gemini-2.5-flash

# Embeddings
EMBEDDING_PROVIDER=openai_compat
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=2048

# Storage
STORAGE_PATH=/storage
MAX_UPLOAD_BYTES=52428800

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Worker
ARQ_MAX_JOBS=5

# Kreuzberg OCR (optional)
KREUZBERG_FORCE_OCR=false
KREUZBERG_OCR_LANGUAGE=deu+eng
